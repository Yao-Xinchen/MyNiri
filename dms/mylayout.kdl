layout {
    background-color "transparent"

    gaps 12

    border {
        width 2
    }

    focus-ring {
        width 2
    }
}

window-rule {
    geometry-corner-radius 20
    clip-to-geometry true
    tiled-state true
    draw-border-with-background false
}

